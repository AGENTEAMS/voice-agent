# Mika Voice Agent — env template. Copy to `.env` and fill. `.env` is gitignored.

# ── Supabase (cloud project) ──────────────────────────────────────────────────
# Dashboard → Project Settings → API  /  Database
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
# Database → Connection string → URI (used for `psql -f seed.sql`)
SUPABASE_DB_URL=

# ── ElevenLabs Conversational AI (owns voice + telephony) ─────────────────────
ELEVENLABS_API_KEY=
# Printed by the provisioning step / visible in the agent builder URL
ELEVENLABS_AGENT_ID=
# ElevenLabs → Phone Numbers → your imported Twilio number → copy its id
ELEVENLABS_PHONE_NUMBER_ID=

# ── Twilio (the number gets imported into ElevenLabs) ─────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Live human-transfer target (E.164) for the transfer_to_human system tool
HUMAN_TRANSFER_NUMBER=

# ── App constants ─────────────────────────────────────────────────────────────
RESTAURANT_ID=11111111-1111-1111-1111-111111111111
